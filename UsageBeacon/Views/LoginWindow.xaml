<Window x:Class="UsageBeacon.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ログイン"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#E8202020"/>
        <SolidColorBrush x:Key="BorderBrush2"  Color="#28FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryText"   Color="#F0F0F0"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#909090"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#0078D4"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#0090E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#0064B0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                                <Setter Property="Foreground" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource SecondaryText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#18FFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12,8,12,12"
            Background="{StaticResource SurfaceBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush2}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24"
                              Opacity="0.55" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <StackPanel Margin="16,14">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Rectangle Width="3" Height="14" RadiusX="1.5" RadiusY="1.5"
                           Fill="{StaticResource AccentBrush}"
                           Margin="0,2,8,0" VerticalAlignment="Top"/>
                <TextBlock x:Name="TitleLabel"
                           Foreground="{StaticResource PrimaryText}"
                           FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Description -->
            <TextBlock x:Name="DescLabel"
                       Foreground="{StaticResource SecondaryText}"
                       FontSize="11" TextWrapping="Wrap" LineHeight="17"
                       Margin="0,0,0,14"/>

            <!-- Open terminal button + WSL button -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="OpenTerminalBtn"
                        Grid.Column="0"
                        Style="{StaticResource PrimaryBtn}"
                        HorizontalAlignment="Stretch"
                        Click="OpenTerminal_Click"/>
                <Button x:Name="OpenWslBtn"
                        Grid.Column="2"
                        Content="WSL"
                        Style="{StaticResource GhostBtn}"
                        Click="OpenWsl_Click"/>
            </Grid>

            <!-- Fallback: copy command -->
            <Button x:Name="CopyCommandBtn"
                    Content="コマンドをコピー（自分のターミナルで実行）"
                    Style="{StaticResource GhostBtn}"
                    HorizontalAlignment="Stretch"
                    Click="CopyCommand_Click"
                    Margin="0,0,0,10"/>

            <!-- Status area -->
            <Border x:Name="StatusArea" Visibility="Collapsed"
                    Background="#0AFFFFFF" CornerRadius="6"
                    Padding="10,7" Margin="0,0,0,10">
                <TextBlock x:Name="StatusLabel"
                           Foreground="{StaticResource SecondaryText}"
                           FontSize="10" TextWrapping="Wrap"/>
            </Border>

            <!-- Footer -->
            <Grid>
                <Button Content="キャンセル" Style="{StaticResource GhostBtn}"
                        HorizontalAlignment="Left"
                        Click="Cancel_Click"/>
                <Button x:Name="DoneBtn" Content="ログイン完了"
                        Style="{StaticResource PrimaryBtn}"
                        HorizontalAlignment="Right"
                        IsEnabled="False"
                        Click="Done_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
