<Window x:Class="UsageBeacon.Views.UsagePopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:UsageBeacon.Controls"
        Title="UsageBeacon"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush"    Color="#CCFFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush2"     Color="#35000000"/>
        <SolidColorBrush x:Key="PrimaryText"      Color="#1A1A1A"/>
        <SolidColorBrush x:Key="SecondaryText"    Color="#454545"/>
        <SolidColorBrush x:Key="TertiaryText"     Color="#707070"/>
        <SolidColorBrush x:Key="DividerBrush"     Color="#20000000"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#0078D4"/>
        <SolidColorBrush x:Key="ErrorBg"          Color="#14FF9800"/>
        <SolidColorBrush x:Key="ErrorText"        Color="#FF9800"/>
        <SolidColorBrush x:Key="HoverBg"          Color="#18000000"/>
        <SolidColorBrush x:Key="PressedBg"        Color="#28000000"/>
        <SolidColorBrush x:Key="ComboBg"          Color="#14000000"/>
        <SolidColorBrush x:Key="MenuBg"           Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="UsageTrackBrush"  Color="#404040"/>

        <Style x:Key="Title" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>
        <Style x:Key="Tiny" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TertiaryText}"/>
            <Setter Property="FontSize"   Value="10"/>
        </Style>

        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource SecondaryText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource PressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The default ComboBox template paints a system-colored chrome and
             dropdown that ignore theme brushes, so both are re-templated. -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground"      Value="{DynamicResource SecondaryText}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bg"
                                                Background="{DynamicResource ComboBg}"
                                                BorderBrush="{DynamicResource BorderBrush2}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Margin="0,0,8,0"
                                                  Data="M 0 0 L 3.5 4 L 7 0 Z"
                                                  Fill="{DynamicResource SecondaryText}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background"
                                                        Value="{DynamicResource HoverBg}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="7,3,20,3"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"/>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   StaysOpen="False">
                                <Border Background="{DynamicResource MenuBg}"
                                        BorderBrush="{DynamicResource BorderBrush2}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,2,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="7,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bg" Background="Transparent"
                                CornerRadius="3" Margin="2,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource PressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="0"/>
        </Style>
    </Window.Resources>

    <Border Margin="4"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="10"
            BorderBrush="{DynamicResource BorderBrush2}"
            BorderThickness="1">

        <StackPanel Margin="16,14">

            <!-- Header -->
            <Grid Margin="0,0,0,12">
                <TextBlock Text="UsageBeacon"
                           Foreground="{DynamicResource PrimaryText}"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="RefreshBtn"
                            Content="↻" Style="{StaticResource LinkBtn}"
                            FontSize="15"
                            Click="Refresh_Click"/>
                    <Button x:Name="CloseBtn" Content="✕" Style="{StaticResource LinkBtn}"
                            FontSize="13"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- Claude -->
            <StackPanel Margin="0,0,0,12">
                <Grid Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="✦ " Style="{StaticResource Title}" Foreground="#D07A42"/>
                        <TextBlock Text="Claude Code" Style="{StaticResource Title}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ClaudeIntegrationBtn"
                                Style="{StaticResource LinkBtn}" Click="ClaudeIntegration_Click"/>
                        <Button x:Name="ClaudeLoginBtn"
                                Style="{StaticResource LinkBtn}" Click="ClaudeLogin_Click"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="ClaudeLoading" Style="{StaticResource Label}"/>

                <StackPanel x:Name="ClaudeContent" Visibility="Collapsed">
                    <StackPanel x:Name="Claude5hPanel">
                        <Grid Margin="0,0,0,3">
                            <TextBlock x:Name="ClaudeFiveHourLabel" Style="{StaticResource Label}"/>
                            <TextBlock x:Name="Claude5hPct" HorizontalAlignment="Right"
                                       FontSize="13" FontWeight="Bold"/>
                        </Grid>
                        <ctrl:UsageBar x:Name="Claude5hBar"/>
                        <TextBlock x:Name="Claude5hReset" Style="{StaticResource Tiny}" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="ClaudeWeeklyRow" Margin="0,8,0,0">
                        <Grid Margin="0,0,0,3">
                            <TextBlock x:Name="ClaudeWeeklyLabel" Style="{StaticResource Label}"/>
                            <TextBlock x:Name="ClaudeWeeklyPct" HorizontalAlignment="Right"
                                       FontSize="13" FontWeight="Bold"/>
                        </Grid>
                        <ctrl:UsageBar x:Name="ClaudeWeeklyBar"/>
                        <TextBlock x:Name="ClaudeWeeklyReset" Style="{StaticResource Tiny}" Margin="0,3,0,0"/>
                    </StackPanel>

                    <Grid x:Name="ClaudeSonnetRow" Margin="0,5,0,0">
                        <TextBlock x:Name="ClaudeSonnetLabel" Style="{StaticResource Label}"/>
                        <TextBlock x:Name="ClaudeSonnetPct" HorizontalAlignment="Right"
                                   FontSize="11"/>
                    </Grid>
                    <TextBlock x:Name="ClaudeFreshness" Style="{StaticResource Tiny}"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Border x:Name="ClaudeError" Visibility="Collapsed"
                        Background="{DynamicResource ErrorBg}"
                        CornerRadius="6" Padding="8,6" Margin="0,6,0,0">
                    <StackPanel>
                        <TextBlock x:Name="ClaudeErrorTitle" Foreground="{DynamicResource ErrorText}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBlock x:Name="ClaudeErrorMsg"
                                   Foreground="{DynamicResource SecondaryText}"
                                   FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Separator Margin="0,0,0,12"/>

            <!-- Codex -->
            <StackPanel Margin="0,0,0,12">
                <Grid Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="▶ " Style="{StaticResource Title}" Foreground="#7A8EE0"/>
                        <TextBlock Text="Codex" Style="{StaticResource Title}"/>
                    </StackPanel>
                    <Button x:Name="CodexLoginBtn" HorizontalAlignment="Right"
                            Style="{StaticResource LinkBtn}" Click="CodexLogin_Click"/>
                </Grid>

                <TextBlock x:Name="CodexLoading" Style="{StaticResource Label}"/>

                <StackPanel x:Name="CodexContent" Visibility="Collapsed">
                    <StackPanel x:Name="Codex5hPanel">
                        <Grid Margin="0,0,0,3">
                            <TextBlock x:Name="CodexFiveHourLabel" Style="{StaticResource Label}"/>
                            <TextBlock x:Name="Codex5hPct" HorizontalAlignment="Right"
                                       FontSize="13" FontWeight="Bold"/>
                        </Grid>
                        <ctrl:UsageBar x:Name="Codex5hBar"/>
                        <TextBlock x:Name="Codex5hReset" Style="{StaticResource Tiny}" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="CodexWeeklyRow" Margin="0,8,0,0">
                        <Grid Margin="0,0,0,3">
                            <TextBlock x:Name="CodexWeeklyLabel" Style="{StaticResource Label}"/>
                            <TextBlock x:Name="CodexWeeklyPct" HorizontalAlignment="Right"
                                       FontSize="13" FontWeight="Bold"/>
                        </Grid>
                        <ctrl:UsageBar x:Name="CodexWeeklyBar"/>
                        <TextBlock x:Name="CodexWeeklyReset" Style="{StaticResource Tiny}" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border x:Name="CodexError" Visibility="Collapsed"
                        Background="{DynamicResource ErrorBg}"
                        CornerRadius="6" Padding="8,6" Margin="0,6,0,0">
                    <StackPanel>
                        <TextBlock x:Name="CodexErrorTitle" Foreground="{DynamicResource ErrorText}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBlock x:Name="CodexErrorMsg"
                                   Foreground="{DynamicResource SecondaryText}"
                                   FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Separator Margin="0,0,0,12"/>

            <!-- Settings -->
            <StackPanel Margin="0,0,0,12">
                <Grid Margin="0,0,0,6">
                    <TextBlock x:Name="PollingIntervalLabel" Style="{StaticResource Label}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="IntervalPicker" HorizontalAlignment="Right" Width="80"
                              SelectionChanged="IntervalPicker_SelectionChanged"/>
                </Grid>
                <TextBlock x:Name="PollingIntervalNote" Style="{StaticResource Tiny}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,6">
                    <TextBlock x:Name="StartupLabel" Style="{StaticResource Label}"
                               VerticalAlignment="Center"/>
                    <CheckBox x:Name="StartupChk" HorizontalAlignment="Right"
                              Checked="StartupChk_Changed" Unchecked="StartupChk_Changed"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                    <TextBlock x:Name="TransparencyLabel" Style="{StaticResource Label}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="TransparencyPicker" HorizontalAlignment="Right" Width="92"
                              SelectionChanged="TransparencyPicker_SelectionChanged"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                    <TextBlock x:Name="MonitorLabel" Style="{StaticResource Label}" VerticalAlignment="Center"/>
                    <Button x:Name="MonitorBtn" HorizontalAlignment="Right"
                            Style="{StaticResource LinkBtn}" Click="Monitor_Click"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                    <TextBlock x:Name="PositionLabel" Style="{StaticResource Label}" VerticalAlignment="Center"/>
                    <Button x:Name="PlacementBtn" HorizontalAlignment="Right"
                            Style="{StaticResource LinkBtn}" Click="Placement_Click"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                    <TextBlock x:Name="LanguageLabel" Style="{StaticResource Label}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="LanguagePicker" HorizontalAlignment="Right" Width="130"
                              SelectionChanged="LanguagePicker_SelectionChanged"/>
                </Grid>
                <Grid>
                    <TextBlock x:Name="ThemeLabel" Style="{StaticResource Label}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ThemePicker" HorizontalAlignment="Right" Width="130"
                              SelectionChanged="ThemePicker_SelectionChanged"/>
                </Grid>
            </StackPanel>

            <Separator Margin="0,0,0,10"/>

            <!-- Footer -->
            <Grid>
                <TextBlock x:Name="FetchedAtLabel" Style="{StaticResource Tiny}"
                           VerticalAlignment="Center"/>
                <Button x:Name="QuitBtn" HorizontalAlignment="Right"
                        Style="{StaticResource LinkBtn}" Click="Quit_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
